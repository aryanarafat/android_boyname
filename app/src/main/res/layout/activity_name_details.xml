            </TextView>

        </LinearLayout>







    </LinearLayout>

    <LinearLayout
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/name_linear_background"
        android:id="@+id/HaramName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">


        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="10dp"
            android:background="@drawable/purple_circle"
            android:padding="10dp"
            android:src="@drawable/details">


        </ImageView>


        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="0dp"
                android:layout_weight="1"
                android:fontFamily="@font/solaimanlipi"
                android:gravity="center_vertical"
                android:text="@string/HaramName"
                android:textColor="@color/text_color"
                android:textSize="19sp">

            </TextView>



            <TextView
                android:layout_width="match_parent"

                android:layout_height="1dp">

            </TextView>

        </LinearLayout>







    </LinearLayout>

    <LinearLayout
        android:id="@+id/MakruhName"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/name_linear_background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">


        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="10dp"
            android:layout_marginStart="40dp"
