<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/color_primary_dark"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <!--        android:layout_marginTop="4dp"-->
    <!--        android:layout_marginLeft="8dp"-->
    <!--        android:layout_marginRight="8dp"-->

    <LinearLayout
        android:id="@+id/main_layout"
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/top_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/toolbar_background"

            android:gravity="center"
            android:orientation="horizontal"
            android:padding="5dp">

            <ImageView
                android:id="@+id/imageview_drawer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:scaleType="center"
                android:src="@drawable/menu" />

            <LinearLayout
                android:id="@+id/linear_menu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/main_titel_textivew"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/solaimanlipi"
                    android:text="হুমায়ূন আহমেদ সমগ্র"
                    android:textColor="@color/titel_text_color"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/main_sub_titel_textview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/solaimanlipi"
                    android:gravity="center"
                    android:text="হারিয়ে যান হুমায়ূন আহমেদের স্বপ্নের রাজ্যে"
                    android:textColor="@color/text_color"
                    android:textSize="13sp" />
            </LinearLayout>


            <ImageView

                android:id="@+id/imageview_rate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:scaleType="center"
                android:src="@drawable/star" />

            <ImageView
                android:id="@+id/imageview_share"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:scaleType="center"
                android:src="@drawable/share" />
        </LinearLayout>





        <LinearLayout
            android:id="@+id/main_tab"
            android:layout_width="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_height="match_parent">



            <LinearLayout
                android:id="@+id/layout_tab1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <include
                    layout="@layout/name_layout"></include>


            </LinearLayout>


            <LinearLayout
                android:layout_weight="1"
                android:id="@+id/layout_tab2"
                android:layout_width="match_parent"
                android:visibility="gone"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="5dp">

                <include
                    layout="@layout/acitiviy_dua">

                </include>


            </LinearLayout>


            <LinearLayout
                android:layout_weight="1"

                android:id="@+id/layout_tab3"
                android:layout_width="match_parent"
                android:visibility="gone"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="5dp">


                <include
                    layout="@layout/dorodh">

                </include>



            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_tab4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_weight="1"

                android:orientation="vertical"
                android:padding="5dp">


                <include
                    layout="@layout/activity_onnano">

                </include>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_tab5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:visibility="gone"
                android:orientation="vertical">


                <include
                    layout="@layout/quran">

                </include>



            </LinearLayout>


            <LinearLayout
                android:id="@+id/layout_tab6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:visibility="gone"
                android:orientation="vertical">


                <include
                    layout="@layout/book">


                </include>

            </LinearLayout>







        </LinearLayout>




        <LinearLayout
            android:layout_margin="8dp"
            android:id="@+id/tab_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/toolbar_background"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">


            <LinearLayout

                android:id="@+id/tab1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:background="@drawable/tab_background"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="5dp"
                    android:src="@drawable/boy">


                </ImageView>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/solaimanlipi"
                    android:text="শিশুদের নাম"
                    android:textColor="@color/titel_text_color"
                    android:textStyle="bold">


                </TextView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="5dp"
                    android:src="@drawable/dua">


                </ImageView>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/solaimanlipi"
                    android:text="দোআ"
                    android:textColor="@color/titel_text_color"
                    android:textStyle="bold">


                </TextView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="5dp"
                    android:src="@drawable/durudh">


                </ImageView>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/solaimanlipi"
                    android:text="দরূদ"
                    android:textColor="@color/titel_text_color"
                    android:textStyle="bold">


                </TextView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="5dp"
                    android:src="@drawable/other">


                </ImageView>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/solaimanlipi"
                    android:text="অন্যান্য"
                    android:textColor="@color/titel_text_color"
                    android:textStyle="bold">


                </TextView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="5dp"
                    android:src="@drawable/quran">


                </ImageView>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/solaimanlipi"
                    android:text="কোরআন"
                    android:textColor="@color/titel_text_color"
                    android:textStyle="bold">


                </TextView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="5dp"
                    android:src="@drawable/book">


                </ImageView>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/solaimanlipi"
                    android:text="গ্রন্থ"
                    android:textColor="@color/titel_text_color"
                    android:textStyle="bold">


                </TextView>

            </LinearLayout>


        </LinearLayout>

    </LinearLayout>




    <!-- buttom_nav -->

    <LinearLayout
        android:visibility="gone"
        android:id="@+id/layout_history"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal">


        <include layout="@layout/activity_history" />

    </LinearLayout>
    <LinearLayout
        android:visibility="gone"
        android:id="@+id/layout_favorite"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal">


        <include layout="@layout/activity_favorite" />

    </LinearLayout>
    <LinearLayout
        android:visibility="gone"
        android:id="@+id/layout_settings"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal">


        <include layout="@layout/settings" />

    </LinearLayout>




    <LinearLayout
        android:id="@+id/bottom_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/toolbar_background"

        >


        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            style="@style/BottomNavigationStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/toolbar_background"
            app:menu="@menu/bottom_nav_menu" />

    </LinearLayout>






</LinearLayout>
